BOT_TOKEN=123456:telegram-bot-token
ADMIN_IDS=123456789,987654321
DB_PATH=data/bot.sqlite3

# Канал, на который пользователь должен подписаться для получения демо.
# REQUIRED_CHANNEL используется для проверки подписки: @username или -100...
# REQUIRED_CHANNEL_URL используется для кнопки подписки: публичная или invite-ссылка.
REQUIRED_CHANNEL=@your_demo_channel
REQUIRED_CHANNEL_URL=https://t.me/your_demo_channel
REVIEWS_CHANNEL_URL=https://t.me/your_reviews_channel
SUPPORT_USERNAME=@your_admin_username

# Telegram Stars использует валюту XTR.
ENABLE_TELEGRAM_STARS=true

# CryptoBot: https://t.me/CryptoBot -> Crypto Pay API
CRYPTOBOT_TOKEN=
CRYPTOBOT_API_URL=https://pay.crypt.bot/api

# Папка для файлов товаров. Файлы из seed уже ссылаются на эти директории.
ASSETS_DIR=data/assets
